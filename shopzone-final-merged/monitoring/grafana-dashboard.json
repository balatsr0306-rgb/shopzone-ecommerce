{
  "title": "ShopZone Application Dashboard",
  "uid": "shopzone-main",
  "panels": [
    {
      "title": "HTTP Requests / Second",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"shopzone-backend\"}[5m]))",
        "legendFormat": "req/s"
      }]
    },
    {
      "title": "Average Response Time (ms)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "avg(rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])) * 1000",
        "legendFormat": "avg ms"
      }]
    },
    {
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
        "legendFormat": "error %"
      }]
    },
    {
      "title": "Running Pods",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
        "expr": "count(kube_pod_status_phase{namespace=\"shopzone\", phase=\"Running\"})",
        "legendFormat": "pods"
      }]
    },
    {
      "title": "HTTP Request Rate by Route",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "targets": [{
        "expr": "sum by (route) (rate(http_requests_total{job=\"shopzone-backend\"}[5m]))",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "title": "CPU Usage by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{
        "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"shopzone\"}[5m]))",
        "legendFormat": "{{pod}}"
      }]
    },
    {
      "title": "Memory Usage by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{
        "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"shopzone\"}) / 1024 / 1024",
        "legendFormat": "{{pod}} (MB)"
      }]
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s"
}
