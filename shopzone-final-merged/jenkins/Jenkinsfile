pipeline {
  agent {
    kubernetes {
      yaml '''
        apiVersion: v1
        kind: Pod
        metadata:
          labels:
            app: jenkins-agent
        spec:
          serviceAccountName: jenkins
          containers:
          - name: kaniko
            image: gcr.io/kaniko-project/executor:v1.23.2-debug
            command:
              - /busybox/cat
            tty: true
            volumeMounts:
              - name: ecr-secret
                mountPath: /kaniko/.docker
          - name: node
            image: node:18-alpine
            command: ["sleep", "infinity"]
            resources:
              requests: { cpu: "300m", memory: "512Mi" }
              limits:   { cpu: "1000m", memory: "1Gi" }
          - name: sonar
            image: sonarsource/sonar-scanner-cli:latest
            command: ["sleep", "infinity"]
            env:
              - name: SONAR_SCANNER_OPTS
                value: "-Xmx1024m"
            resources:
              requests: { cpu: "500m", memory: "1Gi" }
              limits:   { cpu: "1000m", memory: "2Gi" }
          - name: trivy
            image: aquasec/trivy:latest
            command: ["sleep", "infinity"]
            volumeMounts:
              - name: trivy-cache
                mountPath: /root/.cache/trivy
            resources:
              requests: { cpu: "200m", memory: "512Mi" }
              limits:   { cpu: "500m", memory: "1Gi" }
          - name: kubectl
            image: alpine/k8s:1.28.3
            command: ["sleep", "infinity"]
          volumes:
          - name: trivy-cache
            emptyDir: {}
          - name: ecr-secret
            secret:
              secretName: ecr-secret
      '''
    }
  }

  environment {
    AWS_REGION     = 'ap-south-1'
    ECR_REGISTRY   = '187352848533.dkr.ecr.ap-south-1.amazonaws.com'
    IMAGE_TAG      = "v1.${BUILD_NUMBER}"
    BACKEND_IMAGE  = "${ECR_REGISTRY}/shopzone-backend:${IMAGE_TAG}"
    FRONTEND_IMAGE = "${ECR_REGISTRY}/shopzone-frontend:${IMAGE_TAG}"
    SONAR_HOST_URL = 'http://sonarqube.sonarqube.svc.cluster.local:9000/sonar'
    SONAR_TOKEN    = credentials('sonar-token')
    TRIVY_SEVERITY = 'CRITICAL'
  }

  options {
    buildDiscarder(logRotator(numToKeepStr: '15'))
    timeout(time: 45, unit: 'MINUTES')
    timestamps()
    disableConcurrentBuilds()
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
        echo "Commit: ${env.GIT_COMMIT?.take(7)}"
      }
    }

    stage('Lint and Test') {
      parallel {
        stage('Backend Tests') {
          steps {
            container('node') {
              dir('shopzone-final-merged/backend') {
                sh '''
                  npm install
                  npm test -- --passWithNoTests --coverage \
                    --coverageReporters=lcov --coverageDirectory=coverage \
                    2>&1 | tee test-results.txt || true
                '''
              }
            }
          }
        }
        stage('Frontend Tests') {
          steps {
            container('node') {
              dir('shopzone-final-merged/frontend') {
                sh '''
                  npm install
                  echo "Skipping frontend tests"
                '''
              }
            }
          }
        }
      }
    }

    stage('SonarQube Analysis') {
      parallel {
        stage('Backend SonarQube') {
          steps {
            container('sonar') {
              dir('shopzone-final-merged/backend') {
                sh """
                  sonar-scanner \
                    -Dsonar.projectKey=shopzone-backend \
                    -Dsonar.projectName="ShopZone Backend" \
                    -Dsonar.sources=src \
                    -Dsonar.exclusions=node_modules/**,coverage/**,**/*.test.js \
                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                    -Dsonar.host.url=${SONAR_HOST_URL} \
                    -Dsonar.login=${SONAR_TOKEN} \
                    -Dsonar.qualitygate.wait=true \
                    -Dsonar.qualitygate.timeout=120
                """
              }
            }
          }
        }
        stage('Frontend SonarQube') {
          steps {
            container('sonar') {
              dir('shopzone-final-merged/frontend') {
                sh """
                  sonar-scanner \
                    -Dsonar.projectKey=shopzone-frontend \
                    -Dsonar.projectName="ShopZone Frontend" \
                    -Dsonar.sources=src \
                    -Dsonar.exclusions=node_modules/**,build/**,coverage/**,**/*.test.js \
                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                    -Dsonar.host.url=${SONAR_HOST_URL} \
                    -Dsonar.login=${SONAR_TOKEN} \
                    -Dsonar.qualitygate.wait=true \
                    -Dsonar.qualitygate.timeout=120
                """
              }
            }
          }
        }
      }
    }

    stage('Build Backend Image') {
      steps {
        container('kaniko') {
          sh """
            /kaniko/executor \
              --snapshot-mode=redo \
              --cache=false \
              --context=${WORKSPACE}/shopzone-final-merged/backend \
              --dockerfile=${WORKSPACE}/shopzone-final-merged/backend/Dockerfile \
              --destination=${BACKEND_IMAGE} \
              --destination=${ECR_REGISTRY}/shopzone-backend:latest
          """
        }
      }
    }

    stage('Build Frontend Image') {
      steps {
        container('kaniko') {
          sh """
            /kaniko/executor \
              --snapshot-mode=redo \
              --cache=false \
              --ignore-path=/root/.npm \
              --context=${WORKSPACE}/shopzone-final-merged/frontend \
              --dockerfile=${WORKSPACE}/shopzone-final-merged/frontend/Dockerfile \
              --destination=${FRONTEND_IMAGE} \
              --destination=${ECR_REGISTRY}/shopzone-frontend:latest
          """
        }
      }
    }

    stage('Trivy Backend') {
    steps {
        container('trivy') {
            sh """
              mkdir -p /tmp/trivy-backend
              export TRIVY_CACHE_DIR=/tmp/trivy-backend

              trivy image \
                --severity CRITICAL,HIGH,MEDIUM \
                --format json \
                --output trivy-backend-report.json \
                --timeout 10m \
                ${BACKEND_IMAGE} || true

              trivy image \
                --severity ${TRIVY_SEVERITY} \
                --exit-code 0 \
                --timeout 10m \
                ${BACKEND_IMAGE}
            """
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'trivy-backend-report.json', allowEmptyArchive: true
        }
    }
}
    stage('Trivy Frontend') {
    steps {
        container('trivy') {
            sh """
              mkdir -p /tmp/trivy-frontend
              export TRIVY_CACHE_DIR=/tmp/trivy-frontend

              trivy image \
                --severity CRITICAL,HIGH,MEDIUM \
                --format json \
                --output trivy-frontend-report.json \
                --timeout 10m \
                ${FRONTEND_IMAGE} || true

              trivy image \
                --severity ${TRIVY_SEVERITY} \
                --exit-code 0 \
                --timeout 10m \
                ${FRONTEND_IMAGE}
            """
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'trivy-frontend-report.json', allowEmptyArchive: true
        }
    }
}
    stage('Trivy Filesystem') {
    steps {
        container('trivy') {
            sh """
              mkdir -p /tmp/trivy-fs
              export TRIVY_CACHE_DIR=/tmp/trivy-fs

              trivy fs \
                --severity CRITICAL,HIGH \
                --format json \
                --output trivy-fs-backend.json \
                ./shopzone-final-merged/backend || true

              trivy fs \
                --severity CRITICAL,HIGH \
                --format json \
                --output trivy-fs-frontend.json \
                ./shopzone-final-merged/frontend || true
            """
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'trivy-fs-*.json', allowEmptyArchive: true
        }
    }
}
    stage('Update Helm Values') {
        steps {
            container('kubectl') {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'github-token',
                        usernameVariable: 'GITHUB_USER',
                        passwordVariable: 'GITHUB_TOKEN'
                    )
                ]) {
                    sh """
                    pwd
                    ls -la

                    find . -name values.yaml

                    git config --global --add safe.directory /home/jenkins/agent/workspace/shopzone-cicd

                    git status
                    git rev-parse --show-toplevel

                    git fetch origin

                    git checkout main || git checkout -b main origin/main

                    git branch -a
                    git status

                    git pull origin main

                    sed -i "s/tag:.*/tag: \\"${IMAGE_TAG}\\"/g" shopzone-final-merged/helm/shopzone/values.yaml

                    git config user.email "jenkins@shopzone.com"
                    git config user.name "Jenkins CI"

                    git add shopzone-final-merged/helm/shopzone/values.yaml

                    git diff --staged --quiet || \
                    git commit -m "ci: update image tag ${IMAGE_TAG} [skip ci]"

                    git push https://${GITHUB_USER}:${GITHUB_TOKEN}@github.com/balatsr0306-rgb/shopzone-ecommerce.git HEAD:main
                    """
                }
            }
        }
    }

    stage('Verify Deployment') {
      steps {
        container('kubectl') {
          sh '''
            kubectl rollout status deployment/shopzone-backend -n shopzone --timeout=180s
            kubectl rollout status deployment/shopzone-frontend -n shopzone --timeout=180s
            echo "All pods healthy!"
          '''
        }
      }
    }

  }

  post {
    success {
      echo "Pipeline SUCCESS - Image Tag: ${IMAGE_TAG}"
    }
    failure {
      echo "Pipeline FAILED"
    }
    always {
      // publishHTML disabled
      echo "Pipeline finished - reports archived as artifacts"
    }
  }
}
