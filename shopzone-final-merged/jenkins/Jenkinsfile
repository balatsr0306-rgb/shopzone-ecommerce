// ─────────────────────────────────────────────────────────────────────────────
// ShopZone CI/CD Pipeline
// Stages: Checkout → Test → SonarQube → Build Images → Trivy Scan →
//         Push ECR → Update Helm → ArgoCD Sync → Verify
// Jenkins runs as a pod INSIDE EKS — no server installation needed
// ─────────────────────────────────────────────────────────────────────────────

pipeline {
  agent {
    kubernetes {
      yaml '''
        apiVersion: v1
        kind: Pod
        metadata:
          labels:
            app: jenkins-agent
        spec:
          serviceAccountName: jenkins
          containers:

          # ── Docker-in-Docker (build & push images) ──────────────────────
          - name: docker
            image: docker:24-dind
            securityContext:
              privileged: true
            env:
              - name: DOCKER_TLS_CERTDIR
                value: ""
            volumeMounts:
              - name: docker-sock
                mountPath: /var/run/docker.sock

          # ── Node.js (npm test, sonar-scanner) ───────────────────────────
          - name: node
            image: node:18-alpine
            command: ["sleep", "infinity"]
            resources:
              requests: { cpu: "300m", memory: "512Mi" }
              limits:   { cpu: "1000m", memory: "1Gi" }

          # ── SonarQube Scanner ────────────────────────────────────────────
          - name: sonar
            image: sonarsource/sonar-scanner-cli:latest
            command: ["sleep", "infinity"]
            resources:
              requests: { cpu: "200m", memory: "512Mi" }
              limits:   { cpu: "500m", memory: "1Gi" }

          # ── Trivy (security scanning) ────────────────────────────────────
          - name: trivy
            image: aquasec/trivy:latest
            command: ["sleep", "infinity"]
            volumeMounts:
              - name: docker-sock
                mountPath: /var/run/docker.sock
              - name: trivy-cache
                mountPath: /root/.cache/trivy
            resources:
              requests: { cpu: "200m", memory: "512Mi" }
              limits:   { cpu: "500m", memory: "1Gi" }

          # ── kubectl / helm (deploy) ──────────────────────────────────────
          - name: kubectl
            image: alpine/k8s:1.28.3
            command: ["sleep", "infinity"]

          volumes:
          - name: docker-sock
            hostPath:
              path: /var/run/docker.sock
          - name: trivy-cache
            emptyDir: {}
      '''
    }
  }

  // ── Global environment ──────────────────────────────────────────────────
  environment {
    AWS_REGION       = 'ap-south-1'
    ECR_REGISTRY     = credentials('ECR_REGISTRY')   // e.g. 123456.dkr.ecr.ap-south-1.amazonaws.com
    IMAGE_TAG        = "${env.BUILD_NUMBER}-${env.GIT_COMMIT?.take(7) ?: 'latest'}"
    BACKEND_IMAGE    = "${ECR_REGISTRY}/shopzone-backend:${IMAGE_TAG}"
    FRONTEND_IMAGE   = "${ECR_REGISTRY}/shopzone-frontend:${IMAGE_TAG}"
    ARGOCD_SERVER    = credentials('ARGOCD_SERVER')
    ARGOCD_TOKEN     = credentials('ARGOCD_TOKEN')
    SONAR_HOST_URL   = credentials('SONAR_HOST_URL')   // http://sonarqube.sonarqube.svc:9000/sonar
    SONAR_TOKEN      = credentials('SONAR_TOKEN')      // token from SonarQube UI
    // TRIVY_SEVERITY: fail pipeline on CRITICAL only — change to CRITICAL,HIGH to be stricter
    TRIVY_SEVERITY   = 'CRITICAL'
  }

  options {
    buildDiscarder(logRotator(numToKeepStr: '15'))
    timeout(time: 45, unit: 'MINUTES')
    timestamps()
    disableConcurrentBuilds()
  }

  stages {

    // ── STAGE 1: Checkout ─────────────────────────────────────────────────
    stage('📦 Checkout') {
      steps {
        checkout scm
        echo "Branch: ${env.BRANCH_NAME} | Commit: ${env.GIT_COMMIT?.take(7)}"
      }
    }

    // ── STAGE 2: Lint & Unit Tests ────────────────────────────────────────
    stage('🧪 Lint & Test') {
      parallel {

        stage('Backend Tests') {
          steps {
            container('node') {
              dir('backend') {
                sh '''
                  npm ci
                  npm test -- --passWithNoTests --coverage \
                    --coverageReporters=lcov --coverageDirectory=coverage \
                    2>&1 | tee test-results.txt || true
                '''
              }
            }
          }
        }

        stage('Frontend Tests') {
          steps {
            container('node') {
              dir('frontend') {
                sh '''
                  npm ci
                  CI=true npm test -- --passWithNoTests --coverage \
                    --coverageReporters=lcov --coverageDirectory=coverage \
                    2>&1 | tee test-results.txt || true
                '''
              }
            }
          }
        }
      }
    }

    // ── STAGE 3: SonarQube Code Quality Analysis ──────────────────────────
    stage('🔎 SonarQube Analysis') {
      parallel {

        stage('Backend — SonarQube') {
          steps {
            container('sonar') {
              dir('backend') {
                sh """
                  sonar-scanner \
                    -Dsonar.projectKey=shopzone-backend \
                    -Dsonar.projectName="ShopZone Backend" \
                    -Dsonar.sources=src \
                    -Dsonar.exclusions=node_modules/**,coverage/**,**/*.test.js \
                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                    -Dsonar.host.url=${SONAR_HOST_URL} \
                    -Dsonar.login=${SONAR_TOKEN} \
                    -Dsonar.qualitygate.wait=true \
                    -Dsonar.qualitygate.timeout=120
                """
              }
            }
          }
        }

        stage('Frontend — SonarQube') {
          steps {
            container('sonar') {
              dir('frontend') {
                sh """
                  sonar-scanner \
                    -Dsonar.projectKey=shopzone-frontend \
                    -Dsonar.projectName="ShopZone Frontend" \
                    -Dsonar.sources=src \
                    -Dsonar.exclusions=node_modules/**,build/**,coverage/**,**/*.test.js \
                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                    -Dsonar.host.url=${SONAR_HOST_URL} \
                    -Dsonar.login=${SONAR_TOKEN} \
                    -Dsonar.qualitygate.wait=true \
                    -Dsonar.qualitygate.timeout=120
                """
              }
            }
          }
        }
      }
    }

    // ── STAGE 4: ECR Login ────────────────────────────────────────────────
    stage('🔐 ECR Login') {
      steps {
        container('docker') {
          withAWS(region: "${AWS_REGION}", credentials: 'AWS_CREDENTIALS') {
            sh '''
              aws ecr get-login-password --region $AWS_REGION | \
                docker login --username AWS --password-stdin $ECR_REGISTRY
            '''
          }
        }
      }
    }

    // ── STAGE 5: Build Docker Images ──────────────────────────────────────
    stage('🐳 Build Images') {
      parallel {

        stage('Build Backend') {
          steps {
            container('docker') {
              dir('backend') {
                sh "docker build -t ${BACKEND_IMAGE} ."
              }
            }
          }
        }

        stage('Build Frontend') {
          steps {
            container('docker') {
              dir('frontend') {
                sh "docker build -t ${FRONTEND_IMAGE} ."
              }
            }
          }
        }
      }
    }

    // ── STAGE 6: Trivy Image Security Scan ───────────────────────────────
    // Scans built Docker images for OS + library vulnerabilities
    // Pipeline fails ONLY on CRITICAL CVEs (configurable via TRIVY_SEVERITY)
    stage('🛡️ Trivy Security Scan') {
      parallel {

        stage('Trivy — Backend Image') {
          steps {
            container('trivy') {
              sh """
                echo "━━━ Trivy Scan: Backend Image ━━━"

                # Generate HTML report (always — even if vulns found)
                trivy image \
                  --severity CRITICAL,HIGH,MEDIUM \
                  --format template \
                  --template "@contrib/html.tpl" \
                  --output trivy-backend-report.html \
                  --timeout 10m \
                  ${BACKEND_IMAGE} || true

                # Generate JSON report for archiving
                trivy image \
                  --severity CRITICAL,HIGH,MEDIUM \
                  --format json \
                  --output trivy-backend-report.json \
                  --timeout 10m \
                  ${BACKEND_IMAGE} || true

                # GATE: fail pipeline if CRITICAL vulns found in image
                trivy image \
                  --severity ${TRIVY_SEVERITY} \
                  --exit-code 1 \
                  --timeout 10m \
                  ${BACKEND_IMAGE}

                echo "✅ Backend image scan passed"
              """
            }
          }
          post {
            always {
              archiveArtifacts artifacts: 'trivy-backend-report.*', allowEmptyArchive: true
            }
          }
        }

        stage('Trivy — Frontend Image') {
          steps {
            container('trivy') {
              sh """
                echo "━━━ Trivy Scan: Frontend Image ━━━"

                trivy image \
                  --severity CRITICAL,HIGH,MEDIUM \
                  --format template \
                  --template "@contrib/html.tpl" \
                  --output trivy-frontend-report.html \
                  --timeout 10m \
                  ${FRONTEND_IMAGE} || true

                trivy image \
                  --severity CRITICAL,HIGH,MEDIUM \
                  --format json \
                  --output trivy-frontend-report.json \
                  --timeout 10m \
                  ${FRONTEND_IMAGE} || true

                # GATE: fail pipeline if CRITICAL vulns found
                trivy image \
                  --severity ${TRIVY_SEVERITY} \
                  --exit-code 1 \
                  --timeout 10m \
                  ${FRONTEND_IMAGE}

                echo "✅ Frontend image scan passed"
              """
            }
          }
          post {
            always {
              archiveArtifacts artifacts: 'trivy-frontend-report.*', allowEmptyArchive: true
            }
          }
        }

        stage('Trivy — Filesystem Scan') {
          steps {
            container('trivy') {
              sh """
                echo "━━━ Trivy Scan: Source + Dependencies ━━━"

                # Scan backend node_modules / package-lock
                trivy fs \
                  --severity CRITICAL,HIGH \
                  --format json \
                  --output trivy-fs-backend.json \
                  ./backend || true

                # Scan frontend node_modules / package-lock
                trivy fs \
                  --severity CRITICAL,HIGH \
                  --format json \
                  --output trivy-fs-frontend.json \
                  ./frontend || true

                # Print summary to console
                echo "--- Backend Dependencies ---"
                trivy fs --severity CRITICAL,HIGH ./backend || true
                echo "--- Frontend Dependencies ---"
                trivy fs --severity CRITICAL,HIGH ./frontend || true

                echo "✅ Filesystem scan complete"
              """
            }
          }
          post {
            always {
              archiveArtifacts artifacts: 'trivy-fs-*.json', allowEmptyArchive: true
            }
          }
        }
      }
    }

    // ── STAGE 7: Push to ECR ──────────────────────────────────────────────
    // Only runs after ALL Trivy gates pass
    stage('🚀 Push to ECR') {
      steps {
        container('docker') {
          sh """
            docker push ${BACKEND_IMAGE}
            docker push ${FRONTEND_IMAGE}
          """
          script {
            if (env.BRANCH_NAME == 'main') {
              sh """
                docker tag ${BACKEND_IMAGE}  ${ECR_REGISTRY}/shopzone-backend:latest
                docker tag ${FRONTEND_IMAGE} ${ECR_REGISTRY}/shopzone-frontend:latest
                docker push ${ECR_REGISTRY}/shopzone-backend:latest
                docker push ${ECR_REGISTRY}/shopzone-frontend:latest
              """
            }
          }
        }
      }
    }

    // ── STAGE 8: Update Helm Values → ArgoCD picks it up ─────────────────
    stage('📝 Update Helm Values') {
      when { branch 'main' }
      steps {
        container('kubectl') {
          sh """
            sed -i 's|tag: .*shopzone-backend.*|tag: ${IMAGE_TAG}|g'  helm/shopzone/values.yaml || true
            sed -i 's|tag: .*shopzone-frontend.*|tag: ${IMAGE_TAG}|g' helm/shopzone/values.yaml || true

            git config user.email "jenkins@shopzone.com"
            git config user.name  "Jenkins CI"
            git add helm/shopzone/values.yaml
            git diff --staged --quiet || git commit -m "ci: update image tag → ${IMAGE_TAG} [skip ci]"
            git push origin main || true
          """
        }
      }
    }

    // ── STAGE 9: Trigger ArgoCD Sync ─────────────────────────────────────
    stage('🔄 ArgoCD Sync') {
      when { branch 'main' }
      steps {
        sh """
          curl -sf -X POST \
            -H "Authorization: Bearer ${ARGOCD_TOKEN}" \
            -H "Content-Type: application/json" \
            https://${ARGOCD_SERVER}/api/v1/applications/shopzone/sync
          echo "✅ ArgoCD sync triggered"
        """
      }
    }

    // ── STAGE 10: Verify Deployment ───────────────────────────────────────
    stage('✅ Verify Deployment') {
      when { branch 'main' }
      steps {
        container('kubectl') {
          sh '''
            kubectl rollout status deployment/shopzone-backend  -n shopzone --timeout=180s
            kubectl rollout status deployment/shopzone-frontend -n shopzone --timeout=180s
            echo "✅ All pods healthy — deployment complete!"
          '''
        }
      }
    }
  }

  // ── Post actions ─────────────────────────────────────────────────────────
  post {
    success {
      echo "✅ Pipeline SUCCESS — Image Tag: ${IMAGE_TAG}"
      // Optional Slack notification:
      // slackSend channel: '#deployments', color: 'good',
      //   message: "✅ ShopZone deployed: ${IMAGE_TAG} | ${env.BUILD_URL}"
    }
    failure {
      echo "❌ Pipeline FAILED — check Trivy / SonarQube reports above"
      // slackSend channel: '#deployments', color: 'danger',
      //   message: "❌ ShopZone build failed: ${env.BUILD_URL}"
    }
    always {
      // Cleanup built images from agent node
      container('docker') {
        sh "docker rmi ${BACKEND_IMAGE} ${FRONTEND_IMAGE} || true"
      }
      // Publish HTML security reports in Jenkins UI
      publishHTML(target: [
        allowMissing: true,
        alwaysLinkToLastBuild: true,
        keepAll: true,
        reportDir: '.',
        reportFiles: 'trivy-backend-report.html,trivy-frontend-report.html',
        reportName: 'Trivy Security Report'
      ])
    }
  }
}
