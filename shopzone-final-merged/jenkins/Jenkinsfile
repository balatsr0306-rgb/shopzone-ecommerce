// ─────────────────────────────────────────────────────────────────────────────
// ShopZone CI/CD Pipeline
// Stages: Checkout → Test → SonarQube → Build Images → Trivy Scan →
//         Push ECR → Update Helm → ArgoCD Sync → Verify
// Jenkins runs as a pod INSIDE EKS — no server installation needed
// ─────────────────────────────────────────────────────────────────────────────

pipeline {
  agent {
    kubernetes {
      yaml '''
        apiVersion: v1
        kind: Pod
        metadata:
          labels:
            app: jenkins-agent
        spec:
          serviceAccountName: jenkins
          containers:

          # ── Kaniko (build & push images) ────────────────────────────────
          - name: kaniko
            image: gcr.io/kaniko-project/executor:v1.23.2-debug
            command:
              - /busybox/cat
            tty: true
            volumeMounts:
              - name: ecr-secret
                mountPath: /kaniko/.docker

          # ── Node.js (npm test, sonar-scanner) ───────────────────────────
          - name: node
            image: node:18-alpine
            command: ["sleep", "infinity"]
            resources:
              requests: { cpu: "300m", memory: "512Mi" }
              limits:   { cpu: "1000m", memory: "1Gi" }

          # ── SonarQube Scanner ────────────────────────────────────────────
          - name: sonar
            image: sonarsource/sonar-scanner-cli:latest
            command: ["sleep", "infinity"]
            resources:
              requests: { cpu: "200m", memory: "512Mi" }
              limits:   { cpu: "500m", memory: "1Gi" }

          # ── Trivy (security scanning) ────────────────────────────────────
          - name: trivy
            image: aquasec/trivy:latest
            command: ["sleep", "infinity"]
            volumeMounts:
              - name: trivy-cache
                mountPath: /root/.cache/trivy
            resources:
              requests: { cpu: "200m", memory: "512Mi" }
              limits:   { cpu: "500m", memory: "1Gi" }

          # ── kubectl / helm (deploy) ──────────────────────────────────────
          - name: kubectl
            image: alpine/k8s:1.28.3
            command: ["sleep", "infinity"]

          volumes:
          - name: trivy-cache
            emptyDir: {}

          - name: ecr-secret
            secret:
              secretName: ecr-secret
      '''
    }
  }

  // ── Global environment ──────────────────────────────────────────────────
  environment {
    AWS_REGION       = 'ap-south-1'
    ECR_REGISTRY     = '187352848533.dkr.ecr.ap-south-1.amazonaws.com'
    IMAGE_TAG        = "v1.${BUILD_NUMBER}"
    BACKEND_IMAGE    = "${ECR_REGISTRY}/shopzone-backend:${IMAGE_TAG}"
    FRONTEND_IMAGE   = "${ECR_REGISTRY}/shopzone-frontend:${IMAGE_TAG}"
    SONAR_HOST_URL   = 'http://sonarqube.sonarqube.svc.cluster.local:9000'
    SONAR_TOKEN      = credentials('sonar-token')
    // TRIVY_SEVERITY: fail pipeline on CRITICAL only — change to CRITICAL,HIGH to be stricter
    TRIVY_SEVERITY   = 'CRITICAL'
  }

  options {
    buildDiscarder(logRotator(numToKeepStr: '15'))
    timeout(time: 45, unit: 'MINUTES')
    timestamps()
    disableConcurrentBuilds()
  }

  stages {

    // ── STAGE 1: Checkout ─────────────────────────────────────────────────
    stage('📦 Checkout') {
      steps {
        checkout scm
        echo "Branch: ${env.BRANCH_NAME} | Commit: ${env.GIT_COMMIT?.take(7)}"
      }
    }
    stage('Debug Workspace') {
    steps {
        container('node') {
            sh '''
                pwd
                ls -la
                find . -name package-lock.json
            '''
        }
    }
}
    // ── STAGE 2: Lint & Unit Tests ────────────────────────────────────────
    stage('🧪 Lint & Test') {
      parallel {

        stage('Backend Tests') {
          steps {
            container('node') {
              dir('backend') {
                sh '''
                  npm ci
                  npm test -- --passWithNoTests --coverage \
                    --coverageReporters=lcov --coverageDirectory=coverage \
                    2>&1 | tee test-results.txt || true
                '''
              }
            }
          }
        }

        stage('Frontend Tests') {
          steps {
            container('node') {
              dir('frontend') {
                sh '''
                  npm ci
                  CI=true npm test -- --passWithNoTests --coverage \
                    --coverageReporters=lcov --coverageDirectory=coverage \
                    2>&1 | tee test-results.txt || true
                '''
              }
            }
          }
        }
      }
    }

    // ── STAGE 3: SonarQube Code Quality Analysis ──────────────────────────
    stage('🔎 SonarQube Analysis') {
      parallel {

        stage('Backend — SonarQube') {
          steps {
            container('sonar') {
              dir('backend') {
                sh """
                  sonar-scanner \
                    -Dsonar.projectKey=shopzone-backend \
                    -Dsonar.projectName="ShopZone Backend" \
                    -Dsonar.sources=src \
                    -Dsonar.exclusions=node_modules/**,coverage/**,**/*.test.js \
                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                    -Dsonar.host.url=${SONAR_HOST_URL} \
                    -Dsonar.login=${SONAR_TOKEN} \
                    -Dsonar.qualitygate.wait=true \
                    -Dsonar.qualitygate.timeout=120
                """
              }
            }
          }
        }

        stage('Frontend — SonarQube') {
          steps {
            container('sonar') {
              dir('frontend') {
                sh """
                  sonar-scanner \
                    -Dsonar.projectKey=shopzone-frontend \
                    -Dsonar.projectName="ShopZone Frontend" \
                    -Dsonar.sources=src \
                    -Dsonar.exclusions=node_modules/**,build/**,coverage/**,**/*.test.js \
                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                    -Dsonar.host.url=${SONAR_HOST_URL} \
                    -Dsonar.login=${SONAR_TOKEN} \
                    -Dsonar.qualitygate.wait=true \
                    -Dsonar.qualitygate.timeout=120
                """
              }
            }
          }
        }
      }
    }

    stage('🚀 Build & Push Images') {

  parallel {

    stage('Backend') {
      steps {
        container('kaniko') {
          sh """
          /kaniko/executor \
            --context=${WORKSPACE}/backend \
            --dockerfile=${WORKSPACE}/backend/Dockerfile \
            --destination=${BACKEND_IMAGE} \
            --destination=${ECR_REGISTRY}/shopzone-backend:latest
          """
        }
      }
    }

    stage('Frontend') {
      steps {
        container('kaniko') {
          sh """
          /kaniko/executor \
            --context=${WORKSPACE}/frontend \
            --dockerfile=${WORKSPACE}/frontend/Dockerfile \
            --destination=${FRONTEND_IMAGE} \
            --destination=${ECR_REGISTRY}/shopzone-frontend:latest
          """
        }
      }
    }

  }
}

    // ── STAGE 6: Trivy Image Security Scan ───────────────────────────────
    // Scans built Docker images for OS + library vulnerabilities
    // Pipeline fails ONLY on CRITICAL CVEs (configurable via TRIVY_SEVERITY)
    stage('🛡️ Trivy Security Scan') {
      parallel {

        stage('Trivy — Backend Image') {
          steps {
            container('trivy') {
              sh """
                echo "━━━ Trivy Scan: Backend Image ━━━"

                # Generate HTML report (always — even if vulns found)
                trivy image \
                  --severity CRITICAL,HIGH,MEDIUM \
                  --format template \
                  --template "@contrib/html.tpl" \
                  --output trivy-backend-report.html \
                  --timeout 10m \
                  ${BACKEND_IMAGE} || true

                # Generate JSON report for archiving
                trivy image \
                  --severity CRITICAL,HIGH,MEDIUM \
                  --format json \
                  --output trivy-backend-report.json \
                  --timeout 10m \
                  ${BACKEND_IMAGE} || true

                # GATE: fail pipeline if CRITICAL vulns found in image
                trivy image \
                  --severity ${TRIVY_SEVERITY} \
                  --exit-code 1 \
                  --timeout 10m \
                  ${BACKEND_IMAGE}

                echo "✅ Backend image scan passed"
              """
            }
          }
          post {
            always {
              archiveArtifacts artifacts: 'trivy-backend-report.*', allowEmptyArchive: true
            }
          }
        }

        stage('Trivy — Frontend Image') {
          steps {
            container('trivy') {
              sh """
                echo "━━━ Trivy Scan: Frontend Image ━━━"

                trivy image \
                  --severity CRITICAL,HIGH,MEDIUM \
                  --format template \
                  --template "@contrib/html.tpl" \
                  --output trivy-frontend-report.html \
                  --timeout 10m \
                  ${FRONTEND_IMAGE} || true

                trivy image \
                  --severity CRITICAL,HIGH,MEDIUM \
                  --format json \
                  --output trivy-frontend-report.json \
                  --timeout 10m \
                  ${FRONTEND_IMAGE} || true

                # GATE: fail pipeline if CRITICAL vulns found
                trivy image \
                  --severity ${TRIVY_SEVERITY} \
                  --exit-code 1 \
                  --timeout 10m \
                  ${FRONTEND_IMAGE}

                echo "✅ Frontend image scan passed"
              """
            }
          }
          post {
            always {
              archiveArtifacts artifacts: 'trivy-frontend-report.*', allowEmptyArchive: true
            }
          }
        }

        stage('Trivy — Filesystem Scan') {
          steps {
            container('trivy') {
              sh """
                echo "━━━ Trivy Scan: Source + Dependencies ━━━"

                # Scan backend node_modules / package-lock
                trivy fs \
                  --severity CRITICAL,HIGH \
                  --format json \
                  --output trivy-fs-backend.json \
                  ./backend || true

                # Scan frontend node_modules / package-lock
                trivy fs \
                  --severity CRITICAL,HIGH \
                  --format json \
                  --output trivy-fs-frontend.json \
                  ./frontend || true

                # Print summary to console
                echo "--- Backend Dependencies ---"
                trivy fs --severity CRITICAL,HIGH ./backend || true
                echo "--- Frontend Dependencies ---"
                trivy fs --severity CRITICAL,HIGH ./frontend || true

                echo "✅ Filesystem scan complete"
              """
            }
          }
          post {
            always {
              archiveArtifacts artifacts: 'trivy-fs-*.json', allowEmptyArchive: true
            }
          }
        }
      }
    }

    // ── STAGE 8: Update Helm Values → ArgoCD picks it up ─────────────────
   stage('📝 Update Helm Values') {
     when { branch 'main' }

     steps {
       container('kubectl') {

         withCredentials([
           usernamePassword(
             credentialsId: 'github-token',
             usernameVariable: 'GITHUB_USER',
             passwordVariable: 'GITHUB_TOKEN'
           )
         ]) {

           sh """
             sed -i '/backend:/,/pullPolicy:/s/tag:.*/tag: "${IMAGE_TAG}"/' helm/shopzone/values.yaml || true

             sed -i '/frontend:/,/pullPolicy:/s/tag:.*/tag: "${IMAGE_TAG}"/' helm/shopzone/values.yaml || true

             git config user.email "jenkins@shopzone.com"
             git config user.name "Jenkins CI"

             git add helm/shopzone/values.yaml

             git diff --staged --quiet || \
             git commit -m "ci: update image tag ${IMAGE_TAG} [skip ci]"

             git push https://${GITHUB_USER}:${GITHUB_TOKEN}@github.com/balatsr0306-rgb/shopzone-ecommerce.git main
           """
         }
       }
     }
   }

    // ── STAGE 10: Verify Deployment ───────────────────────────────────────
    stage('✅ Verify Deployment') {
      when { branch 'main' }
      steps {
        container('kubectl') {
          sh '''
            kubectl rollout status deployment/shopzone-backend  -n shopzone --timeout=180s
            kubectl rollout status deployment/shopzone-frontend -n shopzone --timeout=180s
            echo "✅ All pods healthy — deployment complete!"
          '''
        }
      }
    }
  }

  // ── Post actions ─────────────────────────────────────────────────────────
  post {
    success {
      echo "✅ Pipeline SUCCESS — Image Tag: ${IMAGE_TAG}"
      // Optional Slack notification:
      // slackSend channel: '#deployments', color: 'good',
      //   message: "✅ ShopZone deployed: ${IMAGE_TAG} | ${env.BUILD_URL}"
    }
    failure {
      echo "❌ Pipeline FAILED — check Trivy / SonarQube reports above"
      // slackSend channel: '#deployments', color: 'danger',
      //   message: "❌ ShopZone build failed: ${env.BUILD_URL}"
    }
    always {
      // Publish HTML security reports in Jenkins UI
      publishHTML(target: [
        allowMissing: true,
        alwaysLinkToLastBuild: true,
        keepAll: true,
        reportDir: '.',
        reportFiles: 'trivy-backend-report.html,trivy-frontend-report.html',
        reportName: 'Trivy Security Report'
      ])
    }
  }
}
